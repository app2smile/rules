#!name=app去广告
#!desc=知乎(首次启动推荐列表广告)/起点/贴吧/vgtime的启动页,穿山甲(如vgtime使用了).使用前请先打开surge的脚本开关,mitm开关(自行确认自己的mitm证书配置已生效). 已知问题:若知乎冷启动开屏广告可以去除,若在运行中只能抓到部分包,可能还会出现开屏广告的情况


[MITM]
hostname = %APPEND% magev6.if.qidian.com, api.zhihu.com, api-access.pangolin-sdk-toutiao.com, afd.baidu.com, news.ssp.qq.com

[Script]
去广告 = type=http-response,pattern=^(https|http)\:\/\/(api-access\.pangolin-sdk-toutiao\.com\/api\/ad\/union\/sdk\/get_ads|afd\.baidu\.com\/afd\/entry|api\.zhihu\.com\/(topstory\/recommend|commercial_api\/real_time_launch_v2)|magev6\.if\.qidian\.com\/argus\/api\/v4\/client\/getsplashscreen|app02\.vgtime\.com\:8080\/vgtime-app\/api\/v2\/init\/ad\.json|news\.ssp\.qq\.com\/app),requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/app2smile/rules/master/js/ad.js,script-update-interval=0
